{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,

  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "dash.html",
          "style.css",
          "app.js",
          "icons.svg",
          "favicon.svg",
          "db.js",
          "db-init.js",
          "logTypes.js"
        ]
      }
    }
  ],

  "rewrites": [
    { "source": "/(.*)", "destination": "/server.js" }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "X-XSS-Protection",         "value": "1; mode=block" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security","value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/(style.css|app.js|icons.svg|favicon.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],

  "redirects": [
    {
      "source": "/server.js",
      "destination": "https://discord.gg/6jS5xDEZd",
      "permanent": false
    },
    {
      "source": "/db.js",
      "destination": "https://discord.gg/6jS5xDEZd",
      "permanent": false
    },
    {
      "source": "/style.css",
      "missing": [{ "type": "header", "key": "sec-fetch-dest", "value": "style" }],
      "destination": "https://discord.gg/6jS5xDEZd",
      "permanent": false
    },
    {
      "source": "/app.js",
      "missing": [{ "type": "header", "key": "sec-fetch-dest", "value": "script" }],
      "destination": "https://discord.gg/6jS5xDEZd",
      "permanent": false
    },
    {
      "source": "/favicon.svg",
      "missing": [{ "type": "header", "key": "sec-fetch-dest", "value": "image" }],
      "destination": "https://discord.gg/6jS5xDEZd",
      "permanent": false
    }
  ]
}
